WECOM_DRY_RUN=1
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_AGENT_SECRET=
WECOM_WEBHOOK_URL=
WECOM_MSG_AUDIT_SECRET=
WECOM_MSG_AUDIT_PRIVATE_KEY=
WECOM_MSG_AUDIT_PRIVATE_KEY_PATH=
WECOM_MSG_AUDIT_SDK_LIB=
WECOM_MSG_AUDIT_START_SEQ=0
WECOM_MSG_AUDIT_LIMIT=100
WECOM_MSG_AUDIT_TIMEOUT=30
WECOM_MSG_AUDIT_PROXY=
WECOM_MSG_AUDIT_PROXY_PASSWORD=
WECOM_CALLBACK_TOKEN=
WECOM_CALLBACK_ENCODING_AES_KEY=
WECOM_TRUSTED_IP=
RUNTIME_MODE=desktop
BOT_DB_PATH=data/bot.sqlite3
BOT_DATA_DIR=data
VISION_PROVIDER=auto
GOOGLE_API_KEY=
GOOGLE_VISION_MODEL=gemini-2.5-flash
GOOGLE_STYLE_MODEL=gemini-2.5-flash
# Optional. Only Gemini requests use this proxy; WeCom official API still
# exits from the server IP configured in 企业可信 IP.
GOOGLE_API_PROXY=
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5-mini
SUPPLIER_REMINDER_TIME=14:00
REPORT_FINALIZE_TIME=15:00
OPS_TABLE_CUTOFF_TIME=18:00
SUPPLIER_IMAGE_QUIET_MINUTES=10
SERVER_SYNC_TARGET=
SERVER_SYNC_SSH_KEY=

# Independent failure alerts. Use a normal SMTP mailbox or an email
# service provider. This does not depend on WeCom.
ALERT_EMAIL_ENABLED=1
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
ALERT_EMAIL_COOLDOWN_SECONDS=3600
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=1
SMTP_STARTTLS=0
SMTP_TIMEOUT=15
